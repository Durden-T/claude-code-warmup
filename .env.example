# Required: Long-lived Claude Code OAuth token
# Generate it by running: claude setup-token
# It starts with sk-ant-oat01-... and is valid for 1 year.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Optional: Warmup messages. JSON array for multiple (one picked randomly per day).
# Plain string also accepted for backward compatibility.
# WARMUP_MESSAGES=["Hello, warm me up!", "Quick ping to reset rate limits.", "Hi Claude!"]
WARMUP_MESSAGES=

# Auto-generated by Vercel — do NOT set manually.
# CRON_SECRET=<auto>
